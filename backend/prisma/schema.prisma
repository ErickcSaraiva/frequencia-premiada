generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Professor {
  id        Int        @id @default(autoincrement())
  nome      String
  email     String     @unique
  senha     String
  presencas Presenca[]
}

model Turma {
  id        Int        @id @default(autoincrement())
  nome      String
  alunos    Aluno[]
  presencas Presenca[]
}

model Disciplina {
  id        Int        @id @default(autoincrement())
  nome      String
  presencas Presenca[]
}

model Aluno {
  id        Int        @id @default(autoincrement())
  nome      String
  tag_nfc   String     @unique
  pontos    Int        @default(0)
  turmaId   Int
  turma     Turma      @relation(fields: [turmaId], references: [id])
  presencas Presenca[]
}

model Presenca {
  id           Int        @id @default(autoincrement())
  alunoId      Int
  turmaId      Int
  disciplinaId Int
  professorId  Int
  data         DateTime   @default(now())
  status       String
  editadoPor   String?
  aluno        Aluno      @relation(fields: [alunoId], references: [id])
  turma        Turma      @relation(fields: [turmaId], references: [id])
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id])
  professor    Professor  @relation(fields: [professorId], references: [id])
}