generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Aluno {
  id        String  @id @default(uuid())
  nome      String
  matricula String  @unique
  nfc_uid   String? @unique
  pontos    Int     @default(0)

  turma   Turma  @relation(fields: [turmaId], references: [id])
  turmaId String

  presencas Presenca[]
}

model Turma {
  id        String     @id @default(uuid())
  nome      String
  alunos    Aluno[]
  presencas Presenca[]

  disciplina   Disciplina? @relation(fields: [disciplinaId], references: [id])
  disciplinaId String?
}

model Presenca {
  id         String   @id @default(uuid())
  data       DateTime @default(now())
  status     String
  editadoPor String?

  aluno   Aluno  @relation(fields: [alunoId], references: [id])
  alunoId String

  turma   Turma  @relation(fields: [turmaId], references: [id])
  turmaId String
}

model Professor {
  id    String @id @default(uuid())
  nome  String
  email String @unique
  senha String
}

model Disciplina {
  id     String  @id @default(uuid())
  nome   String
  turmas Turma[]
}
